{
  "expo": {
    "name": "fin-pet",
    "slug": "fin-pet",
    "version": "1.0.0",
    "scheme": "fin-pet",
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png",
    },
    "plugins": [
      "expo-router",
      [
        "expo-build-properties",
        {
          "ios": {
            "newArchEnabled": true
          },
          "android": {
            "newArchEnabled": true
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "baseUrl": "/fin-pet"
    },
    "sourceDir": "src",
  }
}